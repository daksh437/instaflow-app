<?xml version="1.0" encoding="utf-8"?>
<!-- InstaFlow Splash Screen - Pink to Purple Gradient with White f Logo -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Gradient Background -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#FF6B9D"
                android:centerColor="#C77DFF"
                android:endColor="#7B2CBF" />
        </shape>
    </item>

    <!-- White f Logo - Top Center -->
    <item
        android:width="120dp"
        android:height="120dp"
        android:gravity="center|top"
        android:top="120dp">
        <vector xmlns:android="http://schemas.android.com/apk/res/android"
            android:width="120dp"
            android:height="120dp"
            android:viewportWidth="120"
            android:viewportHeight="120">
            <!-- Stylized flowing 'f' shape -->
            <path
                android:fillColor="#FFFFFF"
                android:pathData="M30,20
                    C30,15 35,10 40,10
                    L50,10
                    C55,10 60,15 60,20
                    L60,40
                    L80,40
                    C85,40 90,45 90,50
                    L90,60
                    C90,65 85,70 80,70
                    L60,70
                    L60,90
                    C60,95 65,100 70,100
                    L80,100
                    C85,100 90,95 90,90
                    L90,70
                    L100,70
                    C105,70 110,65 110,60
                    L110,50
                    C110,45 105,40 100,40
                    L90,40
                    L90,20
                    C90,10 80,0 70,0
                    L40,0
                    C30,0 20,10 20,20
                    L20,40
                    L30,40
                    Z" />
        </vector>
    </item>
</layer-list>
